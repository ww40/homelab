#!/bin/bash

TIMEOUT=30

wait_for_containers() {
  shift
  local containers=("$@")

  for c in "${containers[@]}"; do
    echo "⏳ Waiting for $c..."

    timeout=$TIMEOUT
    while [ $timeout -gt 0 ]; do
      status=$(docker inspect --format='{{.State.Status}}' "$c" 2>/dev/null)

      if [[ "$status" == "running" ]]; then
        echo "✅ $c is running"
        break
      fi

      sleep 2
      timeout=$((timeout - 2))
    done
  done
}

restart_service () {
  SERVICE_PATH=$1

  echo ""
  echo "========================================"
  echo "🔄 Restarting: $SERVICE_PATH"
  echo "========================================"

  cd "$SERVICE_PATH" || exit 1

  docker compose restart

  container_ids=$(docker compose ps -q)

  container_names=()
  for id in $container_ids; do
    name=$(docker inspect --format='{{.Name}}' "$id")
    name=${name#/}
    container_names+=("$name")
  done

  wait_for_containers "${container_names[@]}"
}

