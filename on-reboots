#!/bin/bash

# Max time to wait per service (seconds)
TIMEOUT=60

wait_for_containers() {
  local timeout=$TIMEOUT
  shift
  local containers=("$@")

  echo "Waiting for containers: ${containers[*]}"

  for ((i=0; i<timeout; i++)); do
    all_ready=true

    for c in "${containers[@]}"; do
      status=$(docker inspect --format='{{.State.Status}}' "$c" 2>/dev/null)
      health=$(docker inspect --format='{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$c" 2>/dev/null)

      # Must be running
      if [[ "$status" != "running" ]]; then
        all_ready=false
        break
      fi

      # If healthcheck exists, prefer healthy
      if [[ "$health" != "none" && "$health" != "healthy" ]]; then
        # Allow "starting" to pass after half the timeout
        if (( i < timeout / 2 )); then
          all_ready=false
          break
        fi
      fi
    done

    if $all_ready; then
      echo "Ready: ${containers[*]}"
      return 0
    fi

    sleep 2
  done

<<<<<<< HEAD
  echo "Timeout reached, continuing anyway: ${containers[*]}"
  return 0
}

restart_service () {
  SERVICE_PATH=$1

  echo ""
  echo "========================================"
  echo "Restarting: $SERVICE_PATH"
  echo "========================================"

  cd "$SERVICE_PATH" || {
    echo "Failed to enter $SERVICE_PATH"
    exit 1
  }

  docker compose down
  docker compose up -d

  if [ $? -ne 0 ]; then
    echo "docker compose failed in $SERVICE_PATH"
    exit 1
  fi

  # Get container IDs
  container_ids=$(docker compose ps -q)

  if [ -z "$container_ids" ]; then
    echo "No containers found in $SERVICE_PATH"
    return
  fi

  # Convert IDs
  container_names=()
  for id in $container_ids; do
    name=$(docker inspect --format='{{.Name}}' "$id")
    name=${name#/}
    container_names+=("$name")
  done

  wait_for_containers "${container_names[@]}"
}

